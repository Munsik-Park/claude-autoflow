# AutoFlow project configuration — checked in.
# Generated by setup/init.sh from collected values.
# Never contains secrets. See docs/credentials.md.

github_org: "{{GITHUB_ORG}}"
repo_orchestrator: "{{REPO_ORCHESTRATOR}}"
default_branch: "{{DEFAULT_BRANCH}}"
ci_system: "{{CI_SYSTEM}}"
communication_language: "{{COMMUNICATION_LANGUAGE}}"

repos:
  backend:  "{{REPO_BACKEND}}"   # or "none" for single-repo mode
  frontend: "{{REPO_FRONTEND}}"
  infra:    "{{REPO_INFRA}}"
